html.dark
  color-scheme: dark

html.dark
  body
    background: #1a1a1a
    color: #d4d4d4
  #wrap
    background: #1a1a1a
  a
    color: #b0b0b0
  #banner
    background: #1a1a1a
  #logo, #subtitle
    color: #e0e0e0
  #nav-outer
    background: rgba(30, 30, 30, 0.9)
    border-bottom: 1px solid #333
  @supports (backdrop-filter: saturate(180%) blur(20px))
    #nav-outer
      background: rgba(30, 30, 30, 0.732)
  @supports (-webkit-backdrop-filter: saturate(180%) blur(20px))
    #nav-outer
      background: rgba(30, 30, 30, 0.732)
  .main-nav-link, .nav-icon
    color: #d4d4d4
  .search-form
    background: #2a2a2a
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.5)
  .search-form-input
    color: #d4d4d4
  .search-form-submit
    color: #666
    &:hover, &:focus
      color: #aaa

html.dark
  .article-inner
    background: #222
    border-bottom: 1px solid #333
  .article-title
    color: #e0e0e0
  .article-entry
    color: #d4d4d4
    table
      border-top-color: #555
      border-bottom-color: #555
    th
      border-bottom-color: #555
    blockquote
      if (blockquote == "grey")
        background: #2a2a2a
        border-left-color: #444
    .copy-button
      background: #333
      border-color: #444
      color: #ccc
  .article-more-link a
    background: #2a2a2a
    color: #999
    border-color: #444
  .article-footer a
    color: #888
  .article-share-box
    background: #2a2a2a
    box-shadow: 1px 2px 10px rgba(0, 0, 0, 0.5)
  .article-share-input
    color: #d4d4d4
    border-color: #444
  .article-share-links
    background: #2a2a2a
  .article-gallery
    background: #111

html.dark
  .highlight
    background: #1e1e1e
    border-color: #333
  .article-entry
    pre
      background: #1e1e1e
      border-color: #333
      color: #d4d4d4
    code
      background: #2a2a2a
      text-shadow: none
      color: #d4d4d4
    pre code
      background: none

html.dark
  #footer
    background: #222
    color: #999
  #page-nav
    background: #222
    color: #999
    a:hover
      color: #e0e0e0
    .current
      color: #e0e0e0
  .archive-article-title
    color: #bbb
    &:hover
      color: #999
  .archive-article-line
    border-bottom-color: #444

html.dark
  #mobile-nav
    background: #222
    border-right-color: #333
  .mobile-nav-link
    color: #bbb
  .widget
    border-color: #444
    ul, ol
      ul, ol
        color: #888
  .widget-title
    color: #bbb

html.dark
  .toc-link
    color: #888
  #article-toc
    color: #888

html.dark
  .article-category
    color: #666
    text-shadow: none
  .article-nav-link-wrap
    text-shadow: none
  .article-share-link
    text-shadow: none
    color: #888
  $article-share-link
    color: #888
    text-shadow: none
